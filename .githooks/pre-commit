#!/bin/bash

echo "[INFO]: Running pre-commit formatting..."
PROJECT_DIR=$(git rev-parse --show-toplevel)

# Get a list of all currently staged files
# ACM -> Added, Copied, Modified (excludes deletions!)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# ==========================================
# 1. Handle Backend (Core & Pipeline)
# ==========================================

# Filter for files that should be formatted by spotless (core, pipeline, and root configuration files)
BACKEND_FILES=$(echo "$STAGED_FILES" | grep -E '^(core/|pipeline/|.*\.md$|pom\.xml|\.gitignore|\.gitattributes)' || true)

if [ -n "$BACKEND_FILES" ]; then
  echo "[INFO]: Formatting backend files with Spotless..."

  # Prepend absolute project dir to every file path in order to use mvn spotless:apply -SpotlessFiles
  SPOTLESS_FILES=$(echo "$BACKEND_FILES" | sed "s|^|$PROJECT_DIR/|" | paste -sd "," -)

  # Run Spotless from the root POM so it applies to the parent and all child modules
  if ! mvn -f "$PROJECT_DIR"/pom.xml spotless:apply -DspotlessFiles="$SPOTLESS_FILES" -q; then
    echo "[ERROR]: Spotless formatting failed! Please apply \"mvn spotless:apply\" manually."
    exit 1
  fi

  # Only stage the formatted files!
  echo "$BACKEND_FILES" | xargs git add
fi

# ==========================================
# 2. Handle Frontend/Webapp (Prettier)
# ==========================================

# Filter for files inside the webapp package
WEBAPP_FILES=$(echo "$STAGED_FILES" | grep '^webapp/' || true)

if [ -n "$WEBAPP_FILES" ]; then
  echo "[INFO]: Formatting webapp files with Prettier..."

  # Navigate into the webapp directory so npx uses the local node_modules
  cd "$PROJECT_DIR/webapp" || exit 1

  # Strip the 'webapp/' prefix so Prettier can resolve the files locally
  PRETTIER_FILES=$(echo "$WEBAPP_FILES" | sed "s|^webapp/||")

  # Run Prettier via npx.
  # --ignore-unknown ensures it skips files it doesn't understand (like .png or .ico).
  if ! echo "$PRETTIER_FILES" | xargs pnpm exec prettier --write --ignore-unknown; then
    echo "[ERROR]: Prettier formatting failed! Please check your syntax."
    exit 1
  fi

  # Navigate back to the project root
  cd "$PROJECT_DIR" || exit 1

  # Stage the formatted files!
  echo "$WEBAPP_FILES" | xargs git add
fi

echo "[SUCCESS]: Pre-commit formatting complete."