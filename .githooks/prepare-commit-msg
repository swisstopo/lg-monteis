#!/usr/bin/env bash

MSG_FILE="$1"
SOURCE="$2"

BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Extract MON-XX from branch (case agnostic)
if [[ "$BRANCH" =~ ^([Mm][Oo][Nn]-[0-9]+) ]]; then
    TICKET=$(echo "${BASH_REMATCH[1]}" | tr '[:lower:]' '[:upper:]')
else
    exit 0
fi

FIRST_LINE=$(head -n 1 "$MSG_FILE")

# Already has prefix --> do nothing
if [[ "$FIRST_LINE" =~ ^$TICKET: ]]; then
    exit 0
fi

# If user used -m (message already provided)
if [[ "$SOURCE" == "message" ]]; then

    # Case 1: already has ticket prefix (case agnostic) --> normalize only
    if [[ "$FIRST_LINE" =~ ^([Mm][Oo][Nn]-[0-9]+):(.*)$ ]]; then
        BODY="${BASH_REMATCH[2]}"

        {
            echo "$TICKET:$BODY"
            tail -n +2 "$MSG_FILE"
        } > "${MSG_FILE}.tmp" && mv "${MSG_FILE}.tmp" "$MSG_FILE"

        exit 0
    fi

    # Case 2: no ticket --> add prefix
    {
        echo "$TICKET: $FIRST_LINE"
        tail -n +2 "$MSG_FILE"
    } > "${MSG_FILE}.tmp" && mv "${MSG_FILE}.tmp" "$MSG_FILE"

    exit 0
fi

# Otherwise (editor flow, empty template etc.) add the ticket as default prefix
{
    echo "$TICKET: "
    cat "$MSG_FILE"
} > "${MSG_FILE}.tmp" && mv "${MSG_FILE}.tmp" "$MSG_FILE"