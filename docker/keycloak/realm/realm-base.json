{
  "realm": "monteis",
  "enabled": true,
  "displayName": "MONTEIS",
  "loginTheme": "keycloak",
  "sslRequired": "none",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      { "name": "user", "description": "Standard MONTEIS user" },
      { "name": "admin", "description": "MONTEIS administrator" }
    ]
  },
  "clientScopes": [
    {
      "name": "monteis-backend-audience",
      "description": "Adds the monteis-backend audience to access tokens",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "monteis-backend-audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "monteis-backend",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "monteis-oidc-basic",
      "description": "Base OIDC identity claims (sub, preferred_username). This realm is imported with an explicit clientScopes list, which suppresses Keycloak's built-in scopes, so these mappers are defined here.",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": { "access.token.claim": "true", "introspection.token.claim": "true" }
        },
        {
          "name": "preferred_username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "monteis-spa",
      "name": "MONTEIS SPA (Angular)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "attributes": { "pkce.code.challenge.method": "S256", "post.logout.redirect.uris": "+", "login_theme": "monteis" },
      "redirectUris": [],
      "webOrigins": [],
      "defaultClientScopes": ["monteis-oidc-basic", "monteis-backend-audience"]
    },
    {
      "clientId": "monteis-backend",
      "name": "MONTEIS Core Backend (resource server)",
      "enabled": true,
      "protocol": "openid-connect",
      "bearerOnly": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false
    }
  ],
  "users": []
}
