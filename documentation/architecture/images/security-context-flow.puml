@startuml
!theme plain
autonumber
skinparam maxMessageSize 150

actor Client
participant "Auth Filter" as AuthFilter
participant "MonteisJwtAuthenticationConverter" as Converter
participant "SecurityContextHolder" as Holder
participant "jOOQ Repository" as Repo
participant "RlsConnectionProvider" as ConnProvider
database "PostgreSQL\n(Row-Level Security)" as DB

Client -> AuthFilter : Request (Header: Bearer JWT)
AuthFilter -> AuthFilter : Signatur prüfen (JWKS)
AuthFilter -> Converter : Jwt konvertieren

Converter -> Converter : Rolle user -> api:read,\nRolle admin -> api:write + api:read-all,\nsub & experiment_ids -> MonteisPrincipal
Converter -> Holder : Authentication ablegen\n(Principal + Authorities, für die Dauer des Requests)

AuthFilter -> Repo : filterChain.doFilter(...)
Repo -> ConnProvider : Connection anfordern
ConnProvider -> Holder : Authentication lesen
ConnProvider -> DB : GUCs setzen (transaktionslokal)
Repo -> DB : jOOQ Query (unverändert)
DB -> DB : RLS-Policy filtert Zeilen
DB --> Repo : gefilterte Datensätze
Repo --> Client : Response

@enduml
